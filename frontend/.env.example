# Quill frontend environment.
# Base URL the server-side (Node) calls the Quill backend at.
QUILL_API_BASE_URL=http://localhost:8080

# Sibling app URLs for the top-left app switcher. Baked in at build time
# (see Dockerfile) — a blank value shows that tile disabled rather than
# hiding it. Quill's own URL isn't needed here; it's always "current".
# Note: Forge's local dev server also defaults to :3001, same as Quill's —
# adjust one of them if you run both at once.
NEXT_PUBLIC_ATLAS_URL=http://localhost:3003
NEXT_PUBLIC_TEMPO_URL=http://localhost:3002
NEXT_PUBLIC_FORGE_URL=http://localhost:3001
