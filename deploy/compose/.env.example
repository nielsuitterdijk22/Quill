# Quill deployment environment variables.
# Copy to .env and fill in the required values:
#   cp deploy/compose/.env.example deploy/compose/.env
#
# Every variable listed here has a default that works for local development.
# Anything marked "required in production" must be set when QUILL_ENV=production.

# ---------------------------------------------------------------------------
# Postgres (used by both the Quill API and Forgejo)
# ---------------------------------------------------------------------------

# Database superuser credentials used by the init scripts to create databases.
POSTGRES_USER=quill
POSTGRES_PASSWORD=quill
POSTGRES_DB=quill

# ---------------------------------------------------------------------------
# Quill API (backend)
# ---------------------------------------------------------------------------

# Runtime environment. Set to "production" on any shared or public instance.
# This enforces QUILL_JWT_SECRET and sets the Secure flag on the session cookie.
# Default: development
QUILL_ENV=development

# Address the HTTP server listens on. Default: :8080
# QUILL_HTTP_ADDR=:8080

# JWT signing secret. Required in production. Use a long, random string.
# Generate with: openssl rand -hex 32
# Default: "" (rejected when QUILL_ENV=production)
QUILL_JWT_SECRET=dev-insecure-secret-change-me

# JWT issuer embedded in tokens. Default: quill
# QUILL_JWT_ISSUER=quill

# How long session tokens stay valid before the user must log in again.
# Default: 24h
# QUILL_JWT_TTL=24h

# Postgres connection string. Default: postgres://quill:quill@localhost:5432/quill?sslmode=disable
QUILL_DATABASE_URL=postgres://quill:quill@postgres:5432/quill?sslmode=disable

# Internal URL the Quill API uses to reach Forgejo. Default: http://localhost:3000
QUILL_FORGEJO_BASE_URL=http://forgejo:3000

# Public URL Forgejo is reachable at from a user's browser. Used in clone URLs
# and git push instructions. Defaults to QUILL_FORGEJO_BASE_URL when not set.
# Set this to your public domain when Forgejo is exposed (e.g. https://git.example.com).
# QUILL_FORGEJO_PUBLIC_URL=

# Forgejo admin token for the integration layer (required for repo/PR operations).
# Create it after the stack is up — see deploy/compose/README.md.
QUILL_FORGEJO_ADMIN_TOKEN=

# Shared HMAC secret for inbound Forgejo webhooks. When set, Quill verifies the
# X-Forgejo-Signature-256 header on every webhook. Leave empty only for local dev.
# Default: "" (signature verification skipped when empty)
# QUILL_WEBHOOK_SECRET=

# Comma-separated list of origins the API allows in CORS responses.
# Default: http://localhost:3001
# QUILL_CORS_ALLOWED_ORIGINS=http://localhost:3001

# Read / write timeouts for the HTTP server. Default: 15s / 30s
# QUILL_HTTP_READ_TIMEOUT=15s
# QUILL_HTTP_WRITE_TIMEOUT=30s

# Log level (debug, info, warn, error). Default: info
# QUILL_LOG_LEVEL=info

# Log format (json, text). Default: json
# QUILL_LOG_FORMAT=json

# ---------------------------------------------------------------------------
# Pipeline dispatcher (dispatch service)
# ---------------------------------------------------------------------------

# URL of the standalone pipeline dispatcher. When empty, the API skips
# automatic pipeline dispatch. In the Docker Compose stack this is set to
# http://dispatch:8090 in the api service environment. Default: ""
# QUILL_PIPELINE_DISPATCH_URL=http://dispatch:8090

# Shared secret for API -> dispatcher requests. Leave empty only for local dev
# on a trusted Docker network. Default: ""
QUILL_PIPELINE_DISPATCH_SECRET=dev-dispatch-secret

# ---------------------------------------------------------------------------
# Frontend (Next.js)
# ---------------------------------------------------------------------------

# Internal URL the Next.js server-side uses to call the Quill backend.
# Browser requests go through the /api/backend rewrite instead.
# Default: http://localhost:8080
QUILL_API_BASE_URL=http://api:8080

# Sibling app URLs for the top-left app switcher. Leave any of them blank to
# show that tile disabled instead of linking out. Baked in at build time.
NEXT_PUBLIC_ATLAS_URL=https://atlas.example.com
NEXT_PUBLIC_TEMPO_URL=https://tempo.example.com
NEXT_PUBLIC_FORGE_URL=https://forge.example.com
