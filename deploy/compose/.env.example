# Local dev stack defaults. Copy to `.env` and adjust as needed:
#   cp deploy/compose/.env.example deploy/compose/.env
POSTGRES_USER=quill
POSTGRES_PASSWORD=quill
POSTGRES_DB=quill

# Quill-issued JWT signing secret (override in any shared environment).
QUILL_JWT_SECRET=dev-insecure-secret-change-me

# Forgejo admin token for the integration layer (PR 4+). Create it after the
# stack is up — see deploy/compose/README.md — then paste it here.
QUILL_FORGEJO_ADMIN_TOKEN=
