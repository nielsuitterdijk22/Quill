# Local development environment, loaded by direnv (https://direnv.net).
#
#   cp .envrc.example .envrc
#   direnv allow
#
# The safe dev defaults below work out of the box. Fill in the secrets marked
# CHANGE ME before the corresponding feature will work.

# --- Forgejo -----------------------------------------------------------------
# Mint a real admin token — you cannot invent this value, or Forgejo returns
# "401 access token does not exist". See deploy/compose/README.md#forgejo-admin-token.
export FORGEJO_ADMIN_TOKEN=          # CHANGE ME (empty = repo/PR ops disabled)
export FORGEJO_BASE_URL=http://localhost:3000

# --- Quill backend -----------------------------------------------------------
export QUILL_ENV=development
export QUILL_AUTH_PROVIDER=zitadel
export QUILL_API_BASE_URL=http://localhost:8080
export QUILL_DATABASE_URL=postgres://quill:quill@localhost:5432/quill?sslmode=disable
export QUILL_JWT_SECRET=dev-insecure-secret-change-me
export QUILL_PIPELINE_DISPATCH_SECRET=dev-dispatch-secret

# --- Postgres ----------------------------------------------------------------
export POSTGRES_PORT=5432
export POSTGRES_USER=quill
export POSTGRES_PASSWORD=quill
export POSTGRES_DB=quill

# --- GitHub OAuth (optional; for GitHub sign-in / imports) -------------------
export GITHUB_CLIENT_ID=              # CHANGE ME
export GITHUB_CLIENT_SECRET=          # CHANGE ME

# --- Zitadel (auth provider) -------------------------------------------------
export ZITADEL_MANAGEMENT_TOKEN=      # CHANGE ME (machine-user PAT)
export ZITADEL_ISSUER=https://auth.example.com

export DEPLOY_EXTRA_PROFILES=zitadel

# --- Frontend (Next.js, inlined at build time) -------------------------------
# Sibling app URLs for the top-left app switcher. Leave any of them blank to
# show that tile disabled instead of linking out.
export NEXT_PUBLIC_ATLAS_URL=https://atlas.example.com
export NEXT_PUBLIC_TEMPO_URL=https://tempo.example.com
export NEXT_PUBLIC_FORGE_URL=https://forge.example.com

export NEXT_PUBLIC_ZITADEL_ISSUER=https://auth.example.com
export NEXT_PUBLIC_ZITADEL_CLIENT_ID=      # CHANGE ME
export NEXT_PUBLIC_ZITADEL_PROJECT_ID=     # CHANGE ME
export NEXT_PUBLIC_AUTH_PROVIDER=zitadel

# --- Auth.js (frontend session) ----------------------------------------------
export AUTH_SECRET=$QUILL_JWT_SECRET
export AUTH_URL=http://localhost:3001
